{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile and Run C++",
            "type": "shell",
            "command": "g++ -std=c++23 \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\" && \"${fileDirname}/${fileBasenameNoExtension}\" < input.txt > output.txt",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "never"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Compile and Run C",
            "type": "shell",
            "command": "gcc \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\" && \"${fileDirname}/${fileBasenameNoExtension}\" < input.txt > output.txt",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "never"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run Python (.venv aware)",
            "type": "shell",
            "command": "[ -f \"${workspaceFolder}/.venv/bin/python\" ] && \"${workspaceFolder}/.venv/bin/python\" \"${file}\" < input.txt > output.txt || python3 \"${file}\" < input.txt > output.txt",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "never"
            },
            "problemMatcher": []
        }
    ]
}